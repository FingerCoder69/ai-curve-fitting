      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "from scipy.optimize import differential_evolution\n",
        "\n",
      
        "df = pd.read_csv('xy_data.csv')\n",
        "\n",
     
        "x_target = df['x'].values\n",
        "y_target = df['y'].values"
      ],
      "metadata": {
        "id": "o-D90i91nJpE"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def calculate_l1_loss(guesses):\n",
        "    # 1. three dials the optimizer is currently guessing\n",
        "    theta, m, x_val = guesses\n",
        "\n",
        "    # 2. Calculate t\n",
        "\n",
        "    t_guess = (x_target - x_val) * np.cos(theta) + (y_target - 42) * np.sin(theta)\n",
        "    # 3. Calculate the predicted x and y\n",
        "\n",
        "    x_pred = (t_guess * np.cos(theta)) - (np.exp(m * np.abs(t_guess)) * np.sin(0.3 * t_guess) * np.sin(theta)) + x_val\n",
        "    y_pred = 42 + (t_guess * np.sin(theta)) + (np.exp(m * np.abs(t_guess)) * np.sin(0.3 * t_guess) * np.cos(theta))\n",
        "\n",
        "    # 4. Calculate L1\n",
        "    error_x = np.abs(x_target - x_pred)\n",
        "    error_y = np.abs(y_target - y_pred)\n",
        "    total_loss = np.sum(error_x + error_y)\n",
        "\n",
        "    return total_loss"
      ],
      "metadata": {
        "id": "iw-lE_YWnLsl"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "
      
        "bounds = [\n",
        "    (0, np.deg2rad(50)),          # Theta bounds\n",
        "    (-0.05, 0.05),     # M bounds\n",
        "    (0, 100)           # X bounds\n",
        "]\n",
        "\n",
        "print(\"Starting the optimizer...\")\n",
        "\n",
        "# 2. Run Differential Evolution\n",
        "result = differential_evolution(calculate_l1_loss, bounds)\n",
        "\n",
        "# 3. Print the winning numbers!\n",
        "best_theta_rad = result.x[0]\n",
        "best_m = result.x[1]\n",
        "best_x = result.x[2]\n",
        "\n",
        "# Convert Theta back to degrees for your final answer\n",
        "best_theta_deg = np.rad2deg(best_theta_rad)\n",
        "\n",
        "print(f\"Optimal Theta: {best_theta_deg} degrees\")\n",
        "print(f\"Optimal M: {best_m}\")\n",
        "print(f\"Optimal X: {best_x}\")\n",
        "print(f\"Final L1 Loss: {result.fun}\")"
      ],
